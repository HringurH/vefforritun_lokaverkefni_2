<%- include('partials/header') %>

    <main>
        <h2>Add New Recipe</h2>
        <form action="/uppskriftir/ny" method="POST">
            <label for="name">Recipe Name:</label>
            <input type="text" id="name" name="name" required>

            <label for="description">Description:</label>
            <textarea id="description" name="description" required></textarea>

            <label for="work_level">Work Level:</label>
            <select id="work_level" name="work_level" required>
                <option value="">Select work level</option>
                <option value="easy">Easy</option>
                <option value="medium">Medium</option>
                <option value="hard">Hard</option>
            </select>

            <label for="time_minutes">Time (minutes):</label>
            <input type="number" id="time_minutes" name="time_minutes" required>

            <button type="submit">Add Recipe</button>
        </form>
    </main>

<%- include('partials/footer') %>