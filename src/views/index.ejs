<%- include('partials/header') %>

    <main>
        <div class="grid">
            <% recipes.forEach(recipe => { %>
            <div class="card">
                <img src="<%= recipe.image_path %>" alt="<%= recipe.name %>" class="card-image">
                <h2><%= recipe.name %></h2>
                <p><%= recipe.description %></p>
                <a href="/recipe/<%= recipe.id %>">View recipe</a>
            </div>
            <% }) %>
            <div class="card add-recipe">
                <a href="/recipe/new">Add New Recipe</a>
            </div>
        </div>
    </main>

<%- include('partials/footer') %>