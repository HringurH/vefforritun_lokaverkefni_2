<%- include('partials/header') %>

    <main>
        <div class="card-grid">
            <% recipes.forEach(recipe => { %>
            <div class="card">
                <img src="<%= recipe.image_path %>" alt="<%= recipe.name %>" class="card-image">
                <h2><%= recipe.name %></h2>
                <p><%= recipe.description %></p>
                <a href="/recipes/<%= recipe.name %>">View recipe</a>
            </div>
        <% }) %>
        </div>
    </main>

<%- include('partials/footer') %>