<%- include('partials/header') %>

    <main>
        <article class="details">
            <img src="../<%= recipe.image_path %>" alt="<%= recipe.name %>" class="recipe-img">
            <div class="recipe-info">
                <h2><%= recipe.name %></h2>
                <p><%= recipe.description %></p>
                <p>Work level: <%= recipe.work_level %></p>
                <p><%= recipe.time_minutes %> min.</p>
                <a href="/">Go Back</a>
            </div>
            <div class="ingredients-list">
                <h3>Ingredients:</h3>
                <% if (ingredients != null) {%>
                    <% ingredients.forEach(ingredient => { %>
                        <input type="checkbox" id="<%= ingredient.name %>">
                        <label for="<%= ingredient.name %>"><%= ingredient.name %> (<%= ingredient.quantity %>)</label><br>
                    <% }); %>
                <% } else { %>
                    <p>No ingredients added.</p>
                <% } %>
            </div>
            <div class="steps-list">
                <h3>Steps:</h3>
                <% if (steps != null) { %>
                    <% steps.forEach(step => { %>
                        <p><%= step.step_number %>. <%= step.name %></p>
                        <p><%= step.description %></p>
                        <img src="../<%= step.image_path %>" alt="<%= step.name %>">
                    <% }); %>
                <% } else { %>
                    <p>No steps added.</p>
                <% } %>
            </div>
        </article>
    </main>

<%- include('partials/footer') %>